#!/bin/sh
#
# User extension for the 'lesspipe' utility

case "$1" in
	*.*)
		interpreter="${1##*.}"
		;;
	*)
		read -r shebang _ <"$1"
		case "$shebang" in
			'#!'*) ;;
			*)
				exit 1
		esac
		interpreter="${shebang##*/}"
esac

case "$interpreter" in
	py|python)
		# Rudimentary syntax highlighting for python files.
		sed -e 's/^\([[:space:]]*def \)\([^(]*\)/\1[1;32m\2[m/g' \
			-e 's/^\([[:space:]]*class \)\([^(]*\)/\1[1;31m\2[m/g' \
			-e '/^[^#]*$/s/['\''"][^'\''"]*['\''"]/[36m&[m/g' \
			-e 's/\([^\]\)\(#.*\)/\1[1;34m\2[m/g' \
			"$@"
		 ;;
	*)
		 exit 1
esac

exit 0

