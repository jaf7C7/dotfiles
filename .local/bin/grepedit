#!/bin/sh
# Usage: grep -n <regex> <file> [<file>...] | grepedit
#
# Parses output of `grep -n` and opens $EDITOR at each matching line.
#
# Required input format:
# 	<file_path>:<line_number>[:<line_text>]
#
main() {
	if test $# -gt 0
	then
		exec 0<<-EOF
		$(grep -n --color=always "$@")
		EOF
		set --
	fi
	newline=$(printf '\n')
	while IFS="$newline" read -r location
	do
		echo "$location"
		set -- "$@" "$location"
	done
	echo "$# results found"
	for location
	do
		match=${location#*:*:}
		location=${location%:*}
		file=${location%:*}
		line=${location#*:}
		__prompt_to_open "$file" "$line" "$match" || continue
		$EDITOR +"$line" "$file" </dev/tty
	done
}

blk='\033[30m'
red='\033[31m'
grn='\033[32m'
yel='\033[33m'
blu='\033[34m'
mgt='\033[35m'
cyn='\033[36m'
wht='\033[37m'
clr='\033[0m'

__prompt_to_open() {
	printf "${mgt}%s${cyn}:${grn}%s${cyn}:${clr}%s\n" "$1" "$2" "$3" >&2
	printf "Open in ${cyn}%s${clr}? ${blu}%s${clr} " \
		"$EDITOR" 'y]es/[n]o/[q]uit)' >&2
	while :
	do
		read -r reply </dev/tty
		case $reply in
		[Yy]|[Yy]es)
			return 0
			;;
		[Nn]|[Nn]o)
			return 1
			;;
		[Qq]|[Qq]uit)
			exit 1
			;;
		*)
			echo 'Please respond `y`, `n` or `q`' >&2
		esac
	done
}

main "$@"
