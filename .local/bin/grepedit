#!/bin/sh
#
# grepedit
#
# Like `grep -E`, but opens $EDITOR on each file at the matching line.
#
exec awk '
function usage() {
	print("Usage: grepedit <regex> [<file>...] ") | "cat >&2"
	exit 1
}

BEGIN {
	regex = ARGV[1]
	if (regex == "")
		usage()
	file = ARGV[2]
	if (file == "")
		usage()
	if (system("test -r " file) > 0)
		usage()
}
' "$@"
