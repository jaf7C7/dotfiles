#!/usr/bin/bash
#
# Usage: hex2char <hexcode> [<hexcode>...]
#
# Leading `0x` may be omitted.
#
# Examples:
#     $ hex2char 0x68 0x65 0x6c 0x6c 0x6f
#     hello
#
#     $ hex2char 0x0000203a
#     ›
#
#     $ hex2char 1f600
#     😀
#
main() {
	if [[ $# -eq 0 ]]
	then
		while IFS= read -r line
		do
			# Split the line into tokens.
			set -- $line
		done
	fi
	for arg
	do
		if [[ $arg == *[!0-9a-fA-F]* ]]
		then
			echo "$0: not a valid hexadecimal number: $arg" >&2
			if [[ ${0##*/} == u ]]
			then
				echo 'did you want `U`?' >&2
			fi
			exit 1
		fi
	done
	set -- "${@/#0x/}"
	set -- $(printf '\\U%08x\n' "${@/#/0x}")
	printf '%b' "$@"
	echo
}

main "$@"
