#!/usr/bin/bash
#
# Usage: hex2char <hexcode> [<hexcode>...]
#
# Leading `0x` may be omitted.
#
# Examples:
#     $ hex2char 0x68 0x65 0x6c 0x6c 0x6f
#     hello
#
#     $ hex2char 0x0000203a
#     ›
#
#     $ hex2char 1f600
#     😀
#
main() {
	set -- "${@/#0x/}"
	set -- $(printf '\\U%08x\n' "${@/#/0x}")
	printf '%b' "$@"
	printf '\n'
}

main "$@"
