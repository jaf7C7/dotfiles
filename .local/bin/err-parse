#!/bin/sh
#
# err-parse
#
# Extracts filename, line and column information from test output.  It
# writes a line for each error in the form below:
#
#	<path-to-file>:<line>:<col>
#
# Usage:
#
#	$ node --test | err-parse >.err
#
exec sed -En 's,.*\(((/[^/]+)+:([[:digit:]]+):([[:digit:]]+))\).*,\1,p'
