#!/bin/sh
#
# err-fix
#
# Loops through errors in an error file, invoking $EDITOR on each one in
# turn, jumping to the specific line and column where the error was
# reported.
#
# The error file can be made using `err-parse` (see that file for more
# information).
#
# TODO: Write this in Python !!!
#
main() {
	if test -r "$1"; then
		exec <"$1"
	fi
	while IFS= read -r err; do
		prompt_to_open "$err" || continue
		edit "$err" </dev/tty
	done
}

edit() {
	get_file "$err"
	get_line "$err"
	get_col "$err"
	nano --constantshow +"${line},${col}" "$file"
}

get_file() {
	file="${1%:*:*}"
}

get_line() {
	line="${1%:*}"
	line="${line##*:}"
}

get_col() {
	col="${1##*:}"
}

blk='\033[30m'
red='\033[31m'
grn='\033[32m'
yel='\033[33m'
blu='\033[34m'
mgt='\033[35m'
cyn='\033[36m'
wht='\033[37m'
clr='\033[0m'

prompt_to_open() {
	printf "${mgt}%s${clr}: Open in ${cyn}%s${clr}? ${blu}%s${clr} " \
		"${1:-$err}" "$EDITOR" 'y]es/[n]o/[q]uit)' >&2
	while :; do
		read -r reply </dev/tty
		case $reply in
		[Yy] | [Yy]es)
			return 0
			;;
		[Nn] | [Nn]o)
			return 1
			;;
		[Qq] | [Qq]uit)
			exit 1
			;;
		*)
			echo 'Please respond `y`, `n` or `q`' >&2
			;;
		esac
	done
}

main "$@"
