#!/bin/sh

get_file() {
	file="${1%:*:*}"
}

get_line() {
	line="${1%:*}"
	line="${line##*:}"
}

get_col() {
	col="${1##*:}"
}

prompt_to_open() {
	printf '%s: Open in $EDITOR (%s)? [y]es/[n]o/[q]uit) ' "$1" "$EDITOR" >&2
	while :
	do
		read -r reply
		case $reply in
		[Yy]|[Yy]es)
			return 0
			;;
		[Nn]|[Nn]o)
			return 1
			;;
		[Qq]|[Qq]uit)
			exit 1
			;;
		*)
			echo "Please respond `y`, `n` or `q`" >&2
		esac
	done
}

codium() {
	for err
	do
		prompt_to_open "$err" || continue
		command codium --wait --goto "$err"
	done
}

nano() {
	for err
	do
		prompt_to_open "$err" || continue
		get_file "$err"
		get_line "$err"
		get_col "$err"
		command nano --constantshow +"${line},${col}" "$file"
	done
}

vi() {
	for err
	do
		prompt_to_open "$err"
		get_file "$err"
		get_line "$err"
		get_col "$err"
		command vi +"$line" "$file"
	done
}

main() {
	"$EDITOR" $(cat "${1?}")
}

main "$@"
