#!/bin/sh

def_errfile='.err'

blk='\033[30m'
red='\033[31m'
grn='\033[32m'
yel='\033[33m'
blu='\033[34m'
mgt='\033[35m'
cyn='\033[36m'
wht='\033[37m'
clr='\033[0m'

get_file() {
	file="${1%:*:*}"
}

get_line() {
	line="${1%:*}"
	line="${line##*:}"
}

get_col() {
	col="${1##*:}"
}

prompt_to_open() {
	printf "${mgt}%s${clr}: Open in ${cyn}%s${clr}? ${blu}%s${clr} " \
		"${1:-$err}" '$EDITOR' 'y]es/[n]o/[q]uit)' >&2
	while :
	do
		read -r reply
		case $reply in
		[Yy]|[Yy]es)
			return 0
			;;
		[Nn]|[Nn]o)
			return 1
			;;
		[Qq]|[Qq]uit)
			exit 1
			;;
		*)
			echo 'Please respond `y`, `n` or `q`' >&2
		esac
	done
}

codium() {
	command codium --goto "$err"
}

nano() {
	get_file "$err"
	get_line "$err"
	get_col "$err"
	command nano --constantshow +"${line},${col}" "$file"
}

vi() {
	get_file "$err"
	get_line "$err"
	get_col "$err"
	command vi +"$line" "$file"
}

main() {
	for err in $(cat "${1:-$def_errfile}")
	do
		prompt_to_open "$err" || continue
		"$EDITOR" "$err"
	done
}

main "$@"
