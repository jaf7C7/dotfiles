#!/bin/sh
#
# Usage: hl <regex>  [<file>]
#        hl '/<regex>/,/<regex>/' [<file>]
#
# Highlights words in the first form (like `grep --color`).
# Highlights lines in the second form.
#
# TODO: Write this in python !!!
#
main() {
	case "$1" in
	*,*)
		address="$1"
		regexp=".*"
		;;
	*)
		address="/./"
		regexp="$1"
		;;
	esac
	shift
	# `$address` is not passed as a variable to awk as awk doesn't
	# recognise a single variable as an address range.
	awk -v regexp="$regexp" '
	BEGIN {
		# Make sure `regexp` does not contain an unescaped `"`.
		gsub("\"", "\\\&", regexp)
	}
	'"$address"' {
		gsub(regexp, "\033[1;31m&\033[m")
	}
	{
		print()
	}
	' "$@"
}

main "$@"
