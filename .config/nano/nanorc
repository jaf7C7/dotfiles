include "~/.config/nano/*.nanorc"
extendsyntax sh linter "shellcheck --format=gcc"
extendsyntax sh formatter "shfmt --write"
extendsyntax sh color bold,lightwhite,red "\<(TODO|FIXME|XXX)\>"
extendsyntax javascript header "^#!.*/(env[[:blank:]]+)?node"
extendsyntax javascript color bold,lightwhite,red "\<(TODO|FIXME|XXX)\>"
extendsyntax python tabgives "    "
#extendsyntax python color bold,lightwhite,red "\<(TODO|FIXME|XXX)\>"
extendsyntax markdown tabgives "  "
extendsyntax markdown formatter "mdformat --wrap=72"
extendsyntax markdown color normal,normal "^(    |	)+ *([^*+0-9> 	-]|[*+-]\S|[0-9][^.]).*"
